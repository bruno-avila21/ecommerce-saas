# ── Backend URL ────────────────────────────────────────────────────────────────
# En desarrollo: usa el proxy de Vite (/api → localhost:3001)
# En producción: apunta a tu dominio real
VITE_API_URL=/api
VITE_UPLOADS_URL=http://localhost:3001/uploads

# ── Credenciales storefront (auto-login para leer productos) ───────────────────
# Usá un usuario de solo lectura del sistema de roles
VITE_STOREFRONT_USER=admin
VITE_STOREFRONT_PASS=admin123

# ── Marca (White-Label) ────────────────────────────────────────────────────────
VITE_BRAND_NAME=AutoLux
VITE_BRAND_TAGLINE=Encontrá tu próximo vehículo
VITE_BRAND_DESC=Los mejores vehículos seleccionados para vos.
VITE_WHATSAPP=+5491112345678
VITE_EMAIL=contacto@autolux.com.ar

# ── Tema (Color de acento) ─────────────────────────────────────────────────────
# Amber/Gold (default)
VITE_ACCENT_COLOR=#c9a84c
VITE_ACCENT_LIGHT=#f5ecd4
VITE_ACCENT_DARK=#a07830

# Alternativas listas para usar:
# Azul:   #2563eb / #dbeafe / #1d4ed8
# Verde:  #16a34a / #dcfce7 / #15803d
# Rojo:   #dc2626 / #fee2e2 / #b91c1c
